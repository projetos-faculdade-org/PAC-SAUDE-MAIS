generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum CompanyStatus {
  PENDING
  APPROVED
  REJECTED
}

model Company {
  id           String        @id @default(uuid())
  name         String
  email        String        @unique
  responsible  String
  phone        String?
  passwordHash String
  status       CompanyStatus @default(PENDING)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  activities   Activity[]

  @@map("companies")
}

model Admin {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())

  @@map("admins")
}

model Activity {
  id          String   @id @default(uuid())
  name        String
  description String
  schedule    String
  location    String?
  companyId   String
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("activities")
}
